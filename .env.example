# ─────────────────────────────────────────────────────────────────────────────
# Skyf.gg — centralized configuration
#
# Copy this file to `.env` and fill in the values. Every external integration
# (Kick OAuth, YouTube Data API, loyalty-points sync) is driven from here —
# no code changes required.
#
# Variables prefixed with VITE_ are safe to expose in the client bundle
# (public IDs, endpoints, URLs). Everything else is SERVER-ONLY and must
# never be prefixed with VITE_.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ─────────────────────────────────────────────────────────────────────
# Public origin of this deployment. Must match the redirect URI you register
# in the Kick developer portal (Kick will call `${VITE_PUBLIC_APP_URL}${VITE_KICK_REDIRECT_PATH}`).
# Example: https://skyf.gg
VITE_PUBLIC_APP_URL=""

# ── Kick channel / socials ──────────────────────────────────────────────────
VITE_KICK_CHANNEL="cskyf"
VITE_DISCORD_INVITE="https://discord.gg/skyf"
VITE_INSTAGRAM_HANDLE="skyfcs2"

# ── YouTube Data API v3 ─────────────────────────────────────────────────────
# Create a key at https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=""
VITE_YOUTUBE_CHANNEL_ID="UCqz_7UBp0hlBDGvPr8Vi7LQ"
# Featured hero player. `kind` = "video" | "playlist". Leave `id` empty to
# auto-fall-back to the latest uploaded video from the channel above.
VITE_YT_FEATURED_KIND="video"
VITE_YT_FEATURED_ID=""
# Comma-separated pinned video IDs shown under the player.
VITE_YT_PINNED_IDS=""

# ── Kick Developer (Beta) OAuth ─────────────────────────────────────────────
# Register your app at https://docs.kick.com/getting-started/kick-apps-setup
# The redirect URI you enter there MUST equal:
#   ${VITE_PUBLIC_APP_URL}${VITE_KICK_REDIRECT_PATH}
VITE_KICK_CLIENT_ID=""
KICK_CLIENT_SECRET=""
VITE_KICK_REDIRECT_PATH="/api/auth/kick/callback"
VITE_KICK_SCOPES="user:read channel:read events:subscribe"
# Endpoints — only change if Kick moves them.
VITE_KICK_AUTHORIZE_URL="https://id.kick.com/oauth/authorize"
VITE_KICK_TOKEN_URL="https://id.kick.com/oauth/token"
VITE_KICK_API_BASE="https://api.kick.com/public/v1"

# ── Loyalty points sync ─────────────────────────────────────────────────────
# The endpoint of your Kick-app / bot that returns a user's accumulated
# loyalty points. `{name}` is replaced with the Kick username; if omitted
# the username is appended as the last path segment.
# Example: https://api.mybot.gg/points/{name}
VITE_POINTS_SYNC_URL=""
# Bearer token used server-side to authenticate against the endpoint above.
KICK_POINTS_TOKEN=""
# How often the profile page polls for updated points (ms).
VITE_POINTS_POLL_MS="60000"
# Multiplier: 1 loyalty unit = N gems.
VITE_POINTS_GEMS_PER_UNIT="1"
